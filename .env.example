# ============================================
# Outer Image RFP Portal v3.0 — Environment Variables
# ============================================
# Copy this to .env.local and fill in real values

# Airtable
AIRTABLE_API_KEY=pat_xxxxxxxxxxxxxxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# n8n Webhook (v3 workflow — separate from v2)
N8N_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/rfp-intake-v3

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_xxxxxxxxxxxxxxx

# OpenAI (used in n8n, stored here for portal-side scoring)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxx

# Google Gemini (used in n8n)
GEMINI_API_KEY=AIzaXXXXXXXXXXXXXXXXX

# Admin
ADMIN_PASSWORD=your-admin-password

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
